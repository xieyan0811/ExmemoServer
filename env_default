# Copy this file to .env and fill in the values
# cp env_default .env

# ── OpenAI ──────────────────────────────────────────────
# API Key（必填）
OPENAI_API_KEY=

# 自定义 base URL，使用代理或 Azure 时修改，默认留空即可
OPENAI_BASE_URL=

# ── ASR（语音识别）──────────────────────────────────────
# OpenAI Whisper 模型，目前只有 whisper-1
ASR_MODEL=whisper-1

# ── LLM（文本整理）──────────────────────────────────────
# 用于整理笔记的模型，gpt-4o-mini 性价比最高
LLM_MODEL=gpt-4o-mini

# ── 服务器 ───────────────────────────────────────────────
SERVER_PORT=8100

# ── 代理（可选）─────────────────────────────────────────
HTTP_PROXY=
HTTPS_PROXY=

# ── 数据库 (从旧后端迁移) ──────────────────────────────
PGSQL_HOST=192.168.10.168
PGSQL_PORT=5432
PGSQL_USER=postgres
PGSQL_PASSWORD=xxxx
PGSQL_DB=exmemo
