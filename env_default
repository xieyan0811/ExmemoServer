# Copy this file to .env and fill in the values
# cp env_default .env

# ── OpenAI ──────────────────────────────────────────────
# API Key（必填）
OPENAI_API_KEY=

# 自定义 base URL，使用代理或 Azure 时修改，默认留空即可
OPENAI_BASE_URL=

# ── ASR（语音识别）──────────────────────────────────────
# OpenAI Whisper 模型，目前只有 whisper-1
ASR_MODEL=whisper-1

# ── LLM（文本整理）──────────────────────────────────────
# 用于整理笔记的模型，gpt-4o-mini 性价比最高
LLM_MODEL=gpt-4o-mini

# ── 鉴权 ─────────────────────────────────────────────────
# API 访问令牌，用于接口鉴权
API_TOKEN=800811

# ── JWT 用户认证 ───────────────────────────────────────────
# JWT 签名密钥（生产环境请替换为足够长的随机字符串，切勿泄露）
JWT_SECRET=change-me-to-a-long-random-secret
# JWT 令牌有效期（秒），默认 7 天 = 604800
JWT_LIFETIME_SECONDS=604800

# ── 服务器 ───────────────────────────────────────────────
SERVER_PORT=8100

# ── 代理（可选）─────────────────────────────────────────
HTTP_PROXY=
HTTPS_PROXY=

# ── 数据库 (从旧后端迁移) ──────────────────────────────
PGSQL_HOST=192.168.10.168
PGSQL_PORT=5432
PGSQL_USER=postgres
PGSQL_PASSWORD=xxxx
PGSQL_DB=exmemo

# ── 本地存储 (MinIO 配置) ──────────────────────────────
# 用来统一存放生成的 Markdown 和附件，使两端数据可以访问同一套文件存储

HOST_DATA_DIR=/exports/exmemo/data
MINIO_ENDPOINT=minio_storage:9000
MINIO_ACCESS_KEY=root
MINIO_SECRET_KEY=password
MINIO_BUCKET_NAME=exmemo-data
MINIO_SECURE=false